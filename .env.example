# ============================================================================
# Global Ad Hoc Arbitration Panel — Environment Example
# Copy to .env and adjust. NEVER commit a real .env. NEVER hard-code secrets.
# ============================================================================

# ---- Core ----
NODE_ENV=development
APP_NAME="Global Ad Hoc Arbitration Panel"
API_PORT=4000
WEB_PORT=5173
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000

# ---- PostgreSQL ----
POSTGRES_USER=arbitration
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=arbitration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Prisma connection string (compose service host = "postgres")
DATABASE_URL=postgresql://arbitration:change_me_in_real_env@localhost:5432/arbitration?schema=public

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- JWT / Auth ----
# Generate strong values: `openssl rand -base64 48`
JWT_ACCESS_SECRET=replace_with_strong_random_value
JWT_REFRESH_SECRET=replace_with_another_strong_random_value
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
PASSWORD_PEPPER=replace_with_random_pepper
MFA_ISSUER="Global Ad Hoc Arbitration Panel"

# ---- Account security ----
MAX_FAILED_LOGINS=5
ACCOUNT_LOCK_MINUTES=15

# ---- File storage (abstraction) ----
# STORAGE_DRIVER: local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./storage
SIGNED_URL_TTL=600
MAX_UPLOAD_MB=100
# S3 (used when STORAGE_DRIVER=s3). Works with AWS S3, Cloudflare R2, MinIO, Backblaze B2.
# Leave S3_ENDPOINT empty for AWS S3; set it for S3-compatible providers (path-style is then forced).
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=arbitration-documents
# Leave the keys empty in production to use the instance IAM role / default credential chain.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Force path-style addressing (true for most non-AWS S3-compatible servers; ignored when S3_ENDPOINT is set).
S3_FORCE_PATH_STYLE=false
# Server-side encryption header: AES256 (S3-managed keys) or aws:kms.
S3_SERVER_SIDE_ENCRYPTION=AES256

# ---- Email (abstraction) ----
# EMAIL_DRIVER: console | resend | smtp
EMAIL_DRIVER=console
# For Resend testing you can use the shared sender below without verifying a domain.
# In PRODUCTION set EMAIL_FROM to a sender on a VERIFIED domain (SPF/DKIM/DMARC).
EMAIL_FROM="Arbitration Panel <onboarding@resend.dev>"
# Required when EMAIL_DRIVER=resend. Keep the real key in Render/secret env — never commit it.
RESEND_API_KEY=
# Shared secret for verifying inbound provider delivery webhooks (HMAC-SHA256 of
# the raw body in the X-Webhook-Signature header). Set a strong random value in prod.
EMAIL_WEBHOOK_SECRET=dev-email-webhook-secret
# Where new-registration notifications are sent (comma-separated). If empty, the
# active super-administrators' emails are used.
ADMIN_NOTIFICATION_EMAIL=
# SMTP (alternative driver, not yet implemented)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---- Payments (abstraction) ----
# PAYMENT_DRIVER: manual | stripe
PAYMENT_DRIVER=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Video hearings (abstraction) ----
# VIDEO_DRIVER: placeholder | daily
#   placeholder = deterministic mock rooms (no credentials, for dev/test)
#   daily       = real Daily.co rooms (private rooms + per-participant meeting tokens)
VIDEO_DRIVER=placeholder
# Daily.co (used when VIDEO_DRIVER=daily)
DAILY_API_KEY=
DAILY_API_URL=https://api.daily.co/v1

# ---- Compliance screening (KYC / AML / sanctions) ----
# SCREENING_DRIVER: mock | http
#   mock = deterministic, credential-free screening for dev/test
#   http = a real vendor behind a normalising HTTP endpoint (OpenSanctions, Dilisense, ComplyAdvantage, …)
SCREENING_DRIVER=mock
SCREENING_API_URL=
SCREENING_API_KEY=
# Mock-only: comma-separated name tokens that produce a possible match.
SCREENING_MOCK_BLOCK_TOKENS=BLOCKED,SANCTION,OFAC
# Days a CLEAR screening stays valid before it must be re-run.
SCREENING_VALIDITY_DAYS=365

# ---- Security / CORS / rate limiting ----
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
COOKIE_SECRET=replace_with_random_cookie_secret
