// Global Ad Hoc Arbitration Panel — Prisma data model
// All ids are UUIDs. createdAt/updatedAt everywhere; deletedAt for soft-delete
// where retention/legal hold matters. Confidential access is enforced at the
// service layer via case membership + ConfidentialityLevel — never by global
// role alone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// IDENTITY & ACCESS
// ============================================================================

enum Role {
  INDIVIDUAL
  COMPANY_CLIENT
  LAWYER
  ARBITRATOR
  REGISTRAR
  COUNCIL_MEMBER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash      String
  status            UserStatus @default(PENDING_VERIFICATION)
  emailVerified     Boolean    @default(false)
  emailVerifiedAt   DateTime?
  preferredLanguage String     @default("en")

  // MFA-ready
  mfaEnabled  Boolean @default(false)
  mfaSecret   String?
  mfaRecovery String? // hashed recovery codes (JSON)

  // Lockout
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  // Acceptance tracking
  termsAcceptedAt   DateTime?
  termsVersion      String?
  privacyAcceptedAt DateTime?
  privacyVersion    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  profile           UserProfile?
  roles             UserRole[]
  individual        IndividualProfile?
  lawyer            LawyerProfile?
  arbitrator        ArbitratorProfile?
  companyMembers    CompanyMember[]
  sessions          Session[]
  loginEvents       LoginEvent[]
  emailTokens       EmailToken[]
  caseTeamMembers   CaseTeamMember[]
  documentsUploaded Document[]             @relation("UploadedBy")
  documentActivity  DocumentActivity[]
  messagesSent      CaseMessage[]          @relation("MessageSender")
  notifications     Notification[]
  auditLogs         AuditLog[]
  supportTickets    SupportTicket[]
  identityChecks    IdentityVerification[]
  ruleAcceptances   CaseRuleAcceptance[]

  @@index([status])
}

model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  displayName String
  phone       String?
  avatarUrl   String?
  timezone    String   @default("UTC")
  preferredLanguage String @default("en") // "en" | "ar" — drives notification language
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Role_Definition {
  id          String       @id @default(uuid())
  key         Role         @unique
  description String
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String            @id @default(uuid())
  key         String            @unique
  description String
  roles       Role_Definition[]
  createdAt   DateTime          @default(now())
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role
  grantedAt DateTime @default(now())
  grantedBy String?

  @@unique([userId, role])
  @@index([role])
}

model IndividualProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullLegalName      String
  dateOfBirth        DateTime?
  nationality        String?
  countryOfResidence String?
  idType             String?
  idNumber           String? // store reference only; sensitive numbers tokenised in prod
  addressLine1       String?
  addressLine2       String?
  city               String?
  postalCode         String?
  country            String?
  phone              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Company {
  id                     String    @id @default(uuid())
  legalName              String
  tradingName            String?
  countryOfIncorporation String?
  registrationNumber     String?
  taxInfo                String?
  beneficialOwnerInfo    String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  postalCode             String?
  country                String?
  contactEmail           String?
  contactPhone           String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  members   CompanyMember[]
  documents CompanyDocument[]
}

model CompanyMember {
  id                         String   @id @default(uuid())
  companyId                  String
  company                    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId                     String
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  position                   String?
  isAuthorisedRepresentative Boolean  @default(false)
  createdAt                  DateTime @default(now())

  @@unique([companyId, userId])
}

model CompanyDocument {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title      String
  storageKey String
  createdAt  DateTime @default(now())
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model LawyerProfile {
  id                    String             @id @default(uuid())
  userId                String             @unique
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName              String
  lawFirm               String?
  barAssociation        String?
  barNumber             String?
  jurisdiction          String?
  yearsOfPractice       Int?
  arbitrationExperience String?
  languages             String[]           @default([])
  practiceAreas         String[]           @default([])
  profileSummary        String?
  verificationStatus    VerificationStatus @default(UNVERIFIED)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  documents LawyerDocument[]
}

model LawyerDocument {
  id         String        @id @default(uuid())
  lawyerId   String
  lawyer     LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  kind       String // identity | licence | other
  title      String
  storageKey String
  createdAt  DateTime      @default(now())
}

// ============================================================================
// ARBITRATOR PANEL
// ============================================================================

enum AvailabilityStatus {
  AVAILABLE
  LIMITED
  UNAVAILABLE
}

enum FeeBand {
  STANDARD
  SENIOR
  PREMIUM
}

enum ArbitratorApprovalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  SUSPENDED
  REJECTED
}

model ArbitratorProfile {
  id                       String                   @id @default(uuid())
  userId                   String                   @unique
  user                     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName                 String
  professionalTitle        String?
  photoUrl                 String?
  nationality              String?
  countryOfResidence       String?
  biography                String?
  qualifications           String?
  yearsExperience          Int?
  casesAsSole              Int                      @default(0)
  casesAsChair             Int                      @default(0)
  casesAsCoArbitrator      Int                      @default(0)
  familiarRules            String[]                 @default([])
  jurisdictions            String[]                 @default([])
  hourlyRate               Decimal?                 @db.Decimal(12, 2)
  feeBand                  FeeBand                  @default(STANDARD)
  currency                 String                   @default("USD")
  availability             AvailabilityStatus       @default(AVAILABLE)
  memberships              String[]                 @default([])
  publications             String[]                 @default([])
  speakingEngagements      String[]                 @default([])
  conflictDisclosureStatus String? // last self-disclosure summary
  verificationStatus       VerificationStatus       @default(UNVERIFIED)
  approvalStatus           ArbitratorApprovalStatus @default(DRAFT)

  // Undertakings
  independenceDeclared       Boolean @default(false)
  impartialityDeclared       Boolean @default(false)
  confidentialityUndertaking Boolean @default(false)
  cybersecurityUndertaking   Boolean @default(false)

  cvStorageKey String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  legalFields         ArbitratorExpertise[]
  languages           ArbitratorLanguage[]
  availabilitySlots   ArbitratorAvailability[]
  references          ArbitratorReference[]
  appointments        AppointmentInvitation[]
  conflictDisclosures ConflictDisclosure[]
}

enum ExpertiseKind {
  LEGAL_FIELD
  INDUSTRY
}

model ArbitratorExpertise {
  id           String            @id @default(uuid())
  arbitratorId String
  arbitrator   ArbitratorProfile @relation(fields: [arbitratorId], references: [id], onDelete: Cascade)
  kind         ExpertiseKind
  field        String // ArbitrationField key
  createdAt    DateTime          @default(now())

  @@unique([arbitratorId, kind, field])
  @@index([field])
}

model ArbitratorLanguage {
  id           String            @id @default(uuid())
  arbitratorId String
  arbitrator   ArbitratorProfile @relation(fields: [arbitratorId], references: [id], onDelete: Cascade)
  language     String
  proficiency  String? // native | fluent | working

  @@unique([arbitratorId, language])
}

model ArbitratorAvailability {
  id           String             @id @default(uuid())
  arbitratorId String
  arbitrator   ArbitratorProfile  @relation(fields: [arbitratorId], references: [id], onDelete: Cascade)
  fromDate     DateTime
  toDate       DateTime
  status       AvailabilityStatus @default(AVAILABLE)
  note         String?
}

model ArbitratorReference {
  id           String            @id @default(uuid())
  arbitratorId String
  arbitrator   ArbitratorProfile @relation(fields: [arbitratorId], references: [id], onDelete: Cascade)
  name         String
  organisation String?
  contact      String?
  createdAt    DateTime          @default(now())
}

// ============================================================================
// CASES
// ============================================================================

enum CaseStage {
  DRAFT
  SUBMITTED
  FILING_FEE_PENDING
  ADMINISTRATIVE_REVIEW
  DEFICIENCY_NOTICE_ISSUED
  AWAITING_CLAIMANT_CORRECTION
  CASE_REGISTERED
  NOTICE_BEING_SERVED
  AWAITING_RESPONDENT_REGISTRATION
  AWAITING_RESPONSE
  RESPONSE_RECEIVED
  ARBITRATION_TERMS_PENDING
  TRIBUNAL_APPOINTMENT_PENDING
  CONFLICT_CHECK
  ARBITRATOR_ACCEPTANCE_PENDING
  TRIBUNAL_CONSTITUTED
  PRELIMINARY_CONFERENCE_SCHEDULED
  PROCEDURAL_TIMETABLE_ISSUED
  STATEMENT_OF_CLAIM
  STATEMENT_OF_DEFENCE
  COUNTERCLAIM
  REPLY
  REJOINDER
  DOCUMENT_PRODUCTION
  WITNESS_EVIDENCE
  EXPERT_EVIDENCE
  HEARING_PREPARATION
  HEARING_IN_PROGRESS
  POST_HEARING_SUBMISSIONS
  DELIBERATION
  DRAFT_AWARD
  AWARD_ISSUED
  CORRECTION_OR_INTERPRETATION
  CLOSED
  SUSPENDED
  SETTLED
  WITHDRAWN
  TERMINATED
}

enum PartySide {
  CLAIMANT
  RESPONDENT
}

enum CaseRole {
  CLAIMANT
  CLAIMANT_REPRESENTATIVE
  RESPONDENT
  RESPONDENT_REPRESENTATIVE
  TRIBUNAL_CHAIR
  TRIBUNAL_MEMBER
  TRIBUNAL_SECRETARY
  CASE_REGISTRAR
  OBSERVER
}

model Case {
  id                         String    @id @default(uuid())
  reference                  String    @unique // e.g. GAAP-2026-000123
  title                      String
  stage                      CaseStage @default(DRAFT)
  filingCapacity             String?
  category                   String?
  industry                   String?
  confidentialitySensitivity String?
  filedById                  String?
  seat                       String?
  governingLaw               String?
  language                   String    @default("en")
  numberOfArbitrators        Int?
  appointmentMechanism       String?
  onlineConsent              Boolean   @default(false)
  electronicServiceConsent   Boolean   @default(false)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  deletedAt                  DateTime?
  registeredAt               DateTime?

  parties             CaseParty[]
  teamMembers         CaseTeamMember[]
  agreement           ArbitrationAgreement?
  claims              Claim[]
  reliefRequests      ReliefRequest[]
  statusHistory       CaseStatusHistory[]
  tribunal            Tribunal?
  appointments        AppointmentInvitation[]
  conflictDisclosures ConflictDisclosure[]
  challenges          ArbitratorChallenge[]
  documents           Document[]
  messages            CaseMessage[]
  proceduralOrders    ProceduralOrder[]
  deadlines           Deadline[]
  hearings            Hearing[]
  invoices            Invoice[]
  feeEstimates        FeeEstimate[]
  payments            Payment[]
  awards              Award[]
  complianceChecks    ComplianceCheck[]
  deliberations       DeliberationNote[]

  // Rules engine linkage
  ruleSetLink      CaseRuleSet?
  ruleAcceptances  CaseRuleAcceptance[]
  proceduralEvents CaseProceduralEvent[]
  formalNotices    FormalNotice[]

  // Fees, deposits & ledger
  depositRequests DepositRequest[]
  ledgerEntries   FinancialLedgerEntry[]

  // Normalized rules engine
  ruleExecutions CaseRuleExecution[]
  ruleOverrides  CaseRuleOverride[]
  ruleExceptions CaseRuleException[]
  ruleAuditLogs  RuleAuditLog[]

  // Filings & document production
  filings           Filing[]
  productionRequests ProductionRequest[]

  // Witness & expert evidence
  witnesses         Witness[]
  experts           Expert[]
  evidenceObjections EvidenceObjection[]

  // Default / non-participation proceedings
  defaultProceedings DefaultProceeding[]

  // Interim & emergency measures
  interimMeasures   InterimMeasure[]

  // Expedited track & multi-party
  expeditedTrack   ExpeditedTrack?
  joinderRequests  PartyJoinderRequest[]

  @@index([stage])
}

model CaseParty {
  id                     String    @id @default(uuid())
  caseId                 String
  case                   Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  side                   PartySide
  legalName              String
  legalStatus            String? // individual | company | other
  nationality            String?
  countryOfIncorporation String?
  registrationNumber     String?
  addressLine1           String?
  city                   String?
  country                String?
  email                  String?
  phone                  String?
  serviceInfo            String?
  linkedUserId           String?
  linkedCompanyId        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  representatives PartyRepresentative[]
}

model PartyRepresentative {
  id                 String    @id @default(uuid())
  partyId            String
  party              CaseParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  fullName           String
  firm               String?
  email              String?
  phone              String?
  lawyerUserId       String?
  powerOfAttorneyKey String?
  createdAt          DateTime  @default(now())
}

// Defines WHO can touch a case and in WHAT capacity. This is the spine of
// case-level authorization. Tribunal deliberation access derives only from
// TRIBUNAL_CHAIR / TRIBUNAL_MEMBER rows here.
model CaseTeamMember {
  id       String     @id @default(uuid())
  caseId   String
  case     Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseRole CaseRole
  side     PartySide?
  active   Boolean    @default(true)
  addedAt  DateTime   @default(now())
  addedBy  String?

  @@unique([caseId, userId, caseRole])
  @@index([caseId])
  @@index([userId])
}

model ArbitrationAgreement {
  id                     String    @id @default(uuid())
  caseId                 String    @unique
  case                   Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  hasClause              Boolean   @default(false)
  hasSeparateAgreement   Boolean   @default(false)
  hasSubmissionAgreement Boolean   @default(false)
  contractName           String?
  contractDate           DateTime?
  clauseText             String?
  agreementStorageKey    String?
  agreedRules            String?
  proposedRules          String?
  seat                   String?
  proposedSeat           String?
  governingLaw           String?
  language               String?
  numberOfArbitrators    Int?
  appointmentMechanism   String?
  appointingAuthority    String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Claim {
  id                 String    @id @default(uuid())
  caseId             String
  case               Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title              String
  summaryOfFacts     String?
  legalGrounds       String?
  contractualGrounds String?
  disputeAroseOn     DateTime?
  contractValue      Decimal?  @db.Decimal(18, 2)
  amountClaimed      Decimal?  @db.Decimal(18, 2)
  currency           String    @default("USD")
  interestRequested  Boolean   @default(false)
  isCounterclaim     Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model ReliefRequest {
  id          String   @id @default(uuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  kind        String // monetary | non_monetary | declaratory | interim | urgent
  description String
  amount      Decimal? @db.Decimal(18, 2)
  currency    String?
  urgent      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model CaseStatusHistory {
  id        String     @id @default(uuid())
  caseId    String
  case      Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fromStage CaseStage?
  toStage   CaseStage
  note      String?
  changedBy String?
  createdAt DateTime   @default(now())

  @@index([caseId])
}

// ============================================================================
// TRIBUNAL & APPOINTMENTS
// ============================================================================

enum TribunalComposition {
  SOLE
  THREE_MEMBER
}

model Tribunal {
  id            String              @id @default(uuid())
  caseId        String              @unique
  case          Case                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  composition   TribunalComposition
  constituted   Boolean             @default(false)
  constitutedAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  members       TribunalMember[]
  deliberations DeliberationNote[]
}

enum TribunalRole {
  CHAIR
  CO_ARBITRATOR
  SOLE
  SECRETARY
}

model TribunalMember {
  id               String       @id @default(uuid())
  tribunalId       String
  tribunal         Tribunal     @relation(fields: [tribunalId], references: [id], onDelete: Cascade)
  arbitratorUserId String
  role             TribunalRole
  nominatedBy      PartySide?
  acceptedAt       DateTime?
  createdAt        DateTime     @default(now())

  @@unique([tribunalId, arbitratorUserId])
}

enum AppointmentStatus {
  INVITED
  CONFLICT_CHECK
  ACCEPTED
  DECLINED
  WITHDRAWN
  EXPIRED
}

model AppointmentInvitation {
  id                    String            @id @default(uuid())
  caseId                String
  case                  Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  arbitratorId          String
  arbitrator            ArbitratorProfile @relation(fields: [arbitratorId], references: [id], onDelete: Cascade)
  proposedRole          TribunalRole
  nominatedBy           PartySide?
  status                AppointmentStatus @default(INVITED)
  feeAccepted           Boolean           @default(false)
  availabilityConfirmed Boolean           @default(false)
  respondedAt           DateTime?
  expiresAt             DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([caseId])
  @@index([arbitratorId])
}

model ConflictDisclosure {
  id                   String            @id @default(uuid())
  caseId               String
  case                 Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  arbitratorId         String
  arbitrator           ArbitratorProfile @relation(fields: [arbitratorId], references: [id], onDelete: Cascade)
  hasConflict          Boolean           @default(false)
  disclosureText       String?
  independenceDeclared Boolean           @default(false)
  impartialityDeclared Boolean           @default(false)
  reviewedBy           String?
  reviewedAt           DateTime?
  createdAt            DateTime          @default(now())

  @@index([caseId])
}

enum ChallengeStatus {
  SUBMITTED
  UNDER_REVIEW
  UPHELD
  DISMISSED
  WITHDRAWN
}

model ArbitratorChallenge {
  id                         String          @id @default(uuid())
  caseId                     String
  case                       Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  challengedArbitratorUserId String
  raisedBy                   String
  grounds                    String
  status                     ChallengeStatus @default(SUBMITTED)
  decidedBy                  String?
  decidedAt                  DateTime?
  decisionNote               String?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
}

// ============================================================================
// DOCUMENTS
// ============================================================================

enum ConfidentialityLevel {
  PUBLIC
  CASE_PARTIES
  PARTY_PRIVATE
  TRIBUNAL_ONLY
  ADMIN_ONLY
}

enum VirusScanStatus {
  PENDING
  CLEAN
  INFECTED
  ERROR
}

model Document {
  id                 String               @id @default(uuid())
  caseId             String
  case               Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseDocumentNumber String
  exhibitNumber      String?
  category           String
  title              String
  description        String?
  confidentiality    ConfidentialityLevel @default(CASE_PARTIES)
  visibleToSide      PartySide? // for PARTY_PRIVATE scoping
  privileged         Boolean              @default(false)
  archived           Boolean              @default(false)
  uploadedById       String
  uploadedBy         User                 @relation("UploadedBy", fields: [uploadedById], references: [id])
  currentVersion     Int                  @default(1)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?

  versions DocumentVersion[]
  accesses DocumentAccess[]
  activity DocumentActivity[]

  filingLinks     FilingDocument[]
  productionLinks ProductionDocument[]

  @@unique([caseId, caseDocumentNumber])
  @@index([caseId])
}

model DocumentVersion {
  id           String          @id @default(uuid())
  documentId   String
  document     Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version      Int
  storageKey   String
  fileName     String
  mimeType     String
  fileSize     Int
  fileHash     String
  virusScan    VirusScanStatus @default(PENDING)
  uploadedById String
  createdAt    DateTime        @default(now())

  @@unique([documentId, version])
}

model DocumentAccess {
  id          String    @id @default(uuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId      String?
  caseRole    CaseRole?
  canView     Boolean   @default(true)
  canDownload Boolean   @default(false)
  grantedBy   String?
  createdAt   DateTime  @default(now())
}

enum DocumentAction {
  VIEW
  DOWNLOAD
  UPLOAD
  DELETE
  RESTORE
}

model DocumentActivity {
  id         String         @id @default(uuid())
  documentId String
  document   Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  action     DocumentAction
  ipAddress  String?
  createdAt  DateTime       @default(now())

  @@index([documentId])
}

// ============================================================================
// COMMUNICATIONS & NOTIFICATIONS
// ============================================================================

enum MessageCategory {
  TRIBUNAL_NOTICE
  REGISTRAR_NOTICE
  PARTY_SUBMISSION
  PROCEDURAL
  GENERAL
  ADMIN_PRIVATE
}

model CaseMessage {
  id         String          @id @default(uuid())
  caseId     String
  case       Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User            @relation("MessageSender", fields: [senderId], references: [id])
  category   MessageCategory
  subject    String
  body       String
  // Ex parte guard: substantive party-to-tribunal messages must be all-party
  // visible. Restricted visibility is reserved for administrative categories.
  restricted Boolean         @default(false)
  createdAt  DateTime        @default(now())

  recipients MessageRecipient[]

  @@index([caseId])
}

model MessageRecipient {
  id          String      @id @default(uuid())
  messageId   String
  message     CaseMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId      String
  deliveredAt DateTime?
  readAt      DateTime?

  @@unique([messageId, userId])
}

enum NotificationType {
  CASE_UPDATE
  DEADLINE
  HEARING
  PAYMENT
  APPOINTMENT
  MESSAGE
  SECURITY
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

// ============================================================================
// PROCEDURAL: ORDERS, DEADLINES, HEARINGS
// ============================================================================

model ProceduralOrder {
  id          String   @id @default(uuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  number      Int
  title       String
  body        String
  issuedById  String
  issuedAt    DateTime @default(now())
  documentKey String?

  @@unique([caseId, number])
}

enum DeadlineStatus {
  OPEN
  MET
  MISSED
  EXTENDED
  CANCELLED
  SUSPENDED // clock paused; remaining time preserved until resumption
  WAIVED // requirement excused by an authorised person
  OVERDUE // automatically flagged past-due, pending registrar/tribunal review
}

enum DayKind {
  CALENDAR
  BUSINESS
}

model Deadline {
  id           String         @id @default(uuid())
  caseId       String
  case         Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  dueAt        DateTime
  timezone     String         @default("UTC")
  status       DeadlineStatus @default(OPEN)
  reminderRule String? // e.g. "P7D,P2D,P1D"
  extendedTo   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Rules-engine provenance: how this deadline was computed and from which rule.
  ruleId            String?
  rule              Rule?                @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  definitionKey     String? // RuleDeadlineDefinition.key it was generated from
  triggerEventId    String?
  triggerEvent      CaseProceduralEvent? @relation(fields: [triggerEventId], references: [id], onDelete: SetNull)
  triggerDate       DateTime?
  startDate         DateTime?
  days              Int?
  dayKind           DayKind?
  holidayCalendarId String?
  holidayCalendar   HolidayCalendar?     @relation(fields: [holidayCalendarId], references: [id], onDelete: SetNull)
  responsibleRole   CaseRole?
  requiredAction    String?
  completedAt       DateTime?
  suspendedAt       DateTime? // when the clock was paused (status SUSPENDED)

  extensions DeadlineExtension[]
  reminders  DeadlineReminder[]

  @@index([caseId, dueAt])
}

// A scheduled reminder for a deadline, materialised from the reminderRule
// (e.g. "P7D,P2D,P1D" → 7/2/1 days before due). Escalation reminders are raised
// automatically when a deadline becomes overdue so the registry/tribunal act.
model DeadlineReminder {
  id          String    @id @default(uuid())
  deadlineId  String
  deadline    Deadline  @relation(fields: [deadlineId], references: [id], onDelete: Cascade)
  offsetToken String // ISO-8601 duration token, e.g. "P7D"; "OVERDUE" for escalation
  scheduledFor DateTime
  channel     String    @default("in_app") // in_app | email | registrar | tribunal
  escalation  Boolean   @default(false)
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([deadlineId])
  @@index([scheduledFor, sentAt])
}

// Non-destructive extensions/suspensions/waivers. The original Deadline.dueAt is
// only moved forward AFTER an extension row is written, and the prior value is
// preserved here. Deadlines are never silently overwritten.
enum DeadlineChangeKind {
  EXTENSION
  SUSPENSION
  SHORTENING
  WAIVER
  RESUMPTION
}

model DeadlineExtension {
  id             String             @id @default(uuid())
  deadlineId     String
  deadline       Deadline           @relation(fields: [deadlineId], references: [id], onDelete: Cascade)
  kind           DeadlineChangeKind @default(EXTENSION)
  previousDueAt  DateTime
  newDueAt       DateTime?
  reason         String
  orderedById    String // authorised actor (registrar/tribunal)
  orderReference String? // ProceduralOrder reference if any
  createdAt      DateTime           @default(now())

  @@index([deadlineId])
}

// ============================================================================
// HOLIDAY CALENDARS (for business-day deadline calculation)
// ============================================================================

model HolidayCalendar {
  id        String   @id @default(uuid())
  code      String   @unique // e.g. UNCITRAL_DEFAULT, AE, GB
  name      String
  nameAr    String?
  timezone  String   @default("UTC")
  weekend   Int[]    @default([6, 0]) // ISO-ish day numbers treated as weekend (0=Sun..6=Sat)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  holidays  Holiday[]
  deadlines Deadline[]
}

model Holiday {
  id         String          @id @default(uuid())
  calendarId String
  calendar   HolidayCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  date       DateTime // date-only semantics (midnight UTC of the holiday in calendar tz)
  name       String
  nameAr     String?

  @@unique([calendarId, date])
  @@index([calendarId])
}

// ============================================================================
// RULES ENGINE — version-controlled procedural rules that govern workflows
// A case is pinned to a single RuleSetVersion; later amendments create new
// versions and never mutate rules applied to existing cases.
// ============================================================================

enum RuleVersionStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  WITHDRAWN
}

enum RuleStatus {
  ACTIVE
  DEPRECATED
}

model RuleSet {
  id            String   @id @default(uuid())
  code          String   @unique // e.g. GAAP_ONLINE_ADHOC
  title         String
  titleAr       String?
  description   String?
  descriptionAr String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  versions RuleSetVersion[]
}

model RuleSetVersion {
  id                   String            @id @default(uuid())
  ruleSetId            String
  ruleSet              RuleSet           @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  version              String // semantic-ish label, e.g. "1.0", "2.0"
  status               RuleVersionStatus @default(DRAFT)
  effectiveDate        DateTime?
  supersededAt         DateTime?
  changeSummary        String?
  changeSummaryAr      String?
  // Every generated rule version must carry the mandatory-law / counsel-review notice.
  mandatoryLawNotice   String            @default("Mandatory provisions of the law of the seat prevail over conflicting portal rules. These rules require review by qualified arbitration counsel before production launch.")
  mandatoryLawNoticeAr String?
  publishedById        String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  chapters    RuleChapter[]
  rules       Rule[]
  caseLinks   CaseRuleSet[]
  acceptances CaseRuleAcceptance[]

  @@unique([ruleSetId, version])
  @@index([status])
}

model RuleChapter {
  id        String         @id @default(uuid())
  versionId String
  version   RuleSetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  number    Int
  title     String
  titleAr   String?
  summary   String?
  summaryAr String?
  sortOrder Int            @default(0)

  rules Rule[]

  @@unique([versionId, number])
  @@index([versionId])
}

model Rule {
  id        String         @id @default(uuid())
  versionId String
  version   RuleSetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  chapterId String
  chapter   RuleChapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  number    String // e.g. "4.2"
  title     String
  titleAr   String?
  text      String
  textAr    String?
  status    RuleStatus     @default(ACTIVE)
  sortOrder Int            @default(0)

  // Operational metadata that lets the engine act on the rule.
  triggeringEvent     String? // CaseProceduralEvent.type that activates this rule
  responsibleRole     CaseRole?
  permittedAction     String?
  requiredNotice      String?
  requiredDocuments   String[]  @default([])
  feeConsequence      String?
  defaultConsequence  String?
  extensionAuthority  String? // who may extend related deadlines
  waiverAuthority     String?
  applicableCaseTypes String[]  @default([])
  applicableRoles     String[]  @default([])
  auditRequired       Boolean   @default(true)
  mandatoryLawWarning String?
  publicVisible       Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deadlineDefinitions RuleDeadlineDefinition[]
  generatedDeadlines  Deadline[]

  // Normalized operational graph (engine reacts to triggers → actions).
  triggers             RuleTrigger[]
  noticeRequirements   RuleNoticeRequirement[]
  documentRequirements RuleDocumentRequirement[]
  feeDefinitions       RuleFeeDefinition[]
  permissionReqs       RulePermissionRequirement[]
  executions           CaseRuleExecution[]
  overrides            CaseRuleOverride[]
  exceptions           CaseRuleException[]
  ruleAuditLogs        RuleAuditLog[]

  @@unique([versionId, number])
  @@index([versionId])
  @@index([triggeringEvent])
}

// A reusable deadline rule attached to a Rule: "Response to Notice = 30 calendar
// days from service". CaseDeadlines are generated from these definitions.
model RuleDeadlineDefinition {
  id                 String    @id @default(uuid())
  ruleId             String
  rule               Rule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  key                String // stable key, e.g. RESPONSE_TO_NOTICE
  label              String
  labelAr            String?
  triggerEvent       String // CaseProceduralEvent.type that starts the clock
  days               Int
  dayKind            DayKind   @default(CALENDAR)
  responsibleRole    CaseRole?
  requiredAction     String?
  extensionAuthority String?
  reminderRule       String    @default("P7D,P2D,P1D")

  @@unique([ruleId, key])
}

// Pins a case to exactly one RuleSetVersion. Immutable assignment record.
model CaseRuleSet {
  id                  String         @id @default(uuid())
  caseId              String         @unique
  case                Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  ruleSetVersionId    String
  ruleSetVersion      RuleSetVersion @relation(fields: [ruleSetVersionId], references: [id])
  assignedById        String?
  assignedAt          DateTime       @default(now())
  // Procedural modifications agreed by the parties (JSON), e.g. shortened deadlines.
  agreedModifications String?

  @@index([ruleSetVersionId])
}

// Formal, immutable acceptance of the rules by a user on behalf of a party.
model CaseRuleAcceptance {
  id               String         @id @default(uuid())
  caseId           String
  case             Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  ruleSetVersionId String
  ruleSetVersion   RuleSetVersion @relation(fields: [ruleSetVersionId], references: [id])

  partyRepresented         String?
  representativeAuthority  String?
  acceptedLanguage         String  @default("en")
  seat                     String?
  governingLaw             String?
  languageOfProceedings    String?
  numberOfArbitrators      Int?
  appointmentMethod        String?
  consentElectronicService Boolean @default(false)
  consentOnlineHearings    Boolean @default(false)
  feeAllocationAgreement   String?
  acceptedModifications    String?

  // Evidentiary metadata captured at the moment of acceptance.
  ipAddress         String?
  userAgent         String?
  authMethod        String? // password | mfa | sso
  signatureMetadata String? // JSON: e-signature provider metadata

  // Immutable receipt: a hash over the canonical acceptance payload.
  receiptNumber String   @unique
  receiptHash   String
  acceptedAt    DateTime @default(now())

  @@index([caseId])
  @@index([userId])
}

// The procedural event log. Events are what the rules engine reacts to: they
// start deadline clocks, mark service complete, record commencement, etc.
model CaseProceduralEvent {
  id            String    @id @default(uuid())
  caseId        String
  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type          String // e.g. NOTICE_SERVED, FILING_SUBMITTED, CASE_REGISTERED
  ruleId        String?
  actorUserId   String?
  occurredAt    DateTime  @default(now())
  effectiveDate DateTime? // legally operative date if different from occurredAt
  metadata      String? // JSON
  createdAt     DateTime  @default(now())

  generatedDeadlines Deadline[]
  ruleExecutions     CaseRuleExecution[]

  @@index([caseId])
  @@index([type])
}

// ============================================================================
// ELECTRONIC SERVICE OF DOCUMENTS (Chapter 2)
// Email dispatch alone is never treated as conclusive proof of receipt.
// ============================================================================

enum NoticeType {
  NOTICE_OF_ARBITRATION
  RESPONSE
  PLEADING
  PROCEDURAL_APPLICATION
  TRIBUNAL_NOTICE
  REGISTRAR_NOTICE
  PROCEDURAL_ORDER
  HEARING_NOTICE
  PAYMENT_NOTICE
  AWARD
  CORRECTION
  INTERPRETATION
  DEFICIENCY_NOTICE
}

enum NoticeStatus {
  DRAFT
  ISSUED
  PORTAL_AVAILABLE
  EMAIL_SENT
  DELIVERED
  DELIVERY_FAILED
  ACCESSED
  ACKNOWLEDGED
  SUBSTITUTE_SERVICE_REQUIRED
  SERVICE_COMPLETED
  SERVICE_DISPUTED
}

enum DeliveryChannel {
  PORTAL
  EMAIL
  SMS
  COURIER
  REGISTERED_MAIL
  PERSONAL_DELIVERY
  PUBLICATION
}

enum DeliveryOutcome {
  PENDING
  SENT
  DELIVERED
  BOUNCED
  FAILED
}

model FormalNotice {
  id         String       @id @default(uuid())
  caseId     String
  case       Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type       NoticeType
  subject    String
  body       String
  status     NoticeStatus @default(DRAFT)
  issuedById String
  issuedAt   DateTime?
  documentId String? // optional linked Document
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  recipients  NoticeRecipient[]
  certificate ServiceCertificate?
  documents   NoticeDocument[]

  @@index([caseId])
  @@index([status])
}

// A document attached to a formal notice (a notice may serve several). The
// content hash seals which exact file was served.
model NoticeDocument {
  id          String       @id @default(uuid())
  noticeId    String
  notice      FormalNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  documentId  String? // optional link to a case Document
  filename    String
  contentHash String? // SHA-256 of the served file
  byteSize    Int?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  @@index([noticeId])
}

model NoticeRecipient {
  id                    String       @id @default(uuid())
  noticeId              String
  notice                FormalNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  userId                String?
  label                 String // recipient legal name / role
  email                 String?
  partyId               String?
  status                NoticeStatus @default(ISSUED)
  portalAvailableAt     DateTime?
  firstAccessedAt       DateTime?
  acknowledgedAt        DateTime?
  acknowledgementMethod String?
  createdAt             DateTime     @default(now())

  attempts        NoticeDeliveryAttempt[]
  accessEvents    NoticeAccessEvent[]
  acknowledgements NoticeAcknowledgement[]
  failures        NoticeFailure[]

  @@index([noticeId])
}

// An immutable acknowledgement of receipt by a recipient. Distinct from a mere
// portal access: an explicit, sealed statement that the document was received.
model NoticeAcknowledgement {
  id                String          @id @default(uuid())
  recipientId       String
  recipient         NoticeRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  acknowledgedById  String?
  method            String          @default("portal") // portal | email | signature
  statementText     String?
  ipAddress         String?
  userAgent         String?
  signatureMetadata String? // JSON: e-signature provider metadata
  receiptHash       String // SHA-256 seal over the acknowledgement payload
  createdAt         DateTime        @default(now())

  @@index([recipientId])
}

// A recorded delivery failure on a specific channel. Email dispatch failure is
// never silently dropped: it is captured here and may trigger substitute service.
model NoticeFailure {
  id                String          @id @default(uuid())
  recipientId       String
  recipient         NoticeRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  channel           DeliveryChannel
  reason            String
  detail            String?
  substituteOrderId String? // SubstituteServiceOrder that addressed this failure
  resolvedAt        DateTime?
  createdAt         DateTime        @default(now())

  @@index([recipientId])
}

model NoticeDeliveryAttempt {
  id          String          @id @default(uuid())
  recipientId String
  recipient   NoticeRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  channel     DeliveryChannel
  outcome     DeliveryOutcome @default(PENDING)
  detail      String?
  providerRef String?
  createdAt   DateTime        @default(now())

  @@index([recipientId])
}

model NoticeAccessEvent {
  id          String          @id @default(uuid())
  recipientId String
  recipient   NoticeRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  action      String // OPENED | DOWNLOADED
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime        @default(now())

  @@index([recipientId])
}

// Order by tribunal/registrar for additional service by non-electronic means.
model SubstituteServiceOrder {
  id           String          @id @default(uuid())
  noticeId     String
  method       DeliveryChannel
  orderedById  String
  instructions String
  completedAt  DateTime?
  createdAt    DateTime        @default(now())

  @@index([noticeId])
}

// Immutable Certificate of Electronic Service generated from the audit trail.
model ServiceCertificate {
  id                String       @id @default(uuid())
  noticeId          String       @unique
  notice            FormalNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  certificateNumber String       @unique
  generatedById     String
  generatedAt       DateTime     @default(now())
  payload           String // JSON snapshot: recipients, methods, timestamps, statuses
  payloadHash       String
  documentKey       String? // storage key of the generated certificate PDF
  documentHash      String? // SHA-256 of the generated PDF (tamper-evident)
}

enum HearingStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  ADJOURNED
  CANCELLED
}

model Hearing {
  id                 String        @id @default(uuid())
  caseId             String
  case               Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title              String
  scheduledStart     DateTime
  scheduledEnd       DateTime?
  timezone           String        @default("UTC")
  status             HearingStatus @default(SCHEDULED)
  provider           String        @default("placeholder")
  agenda             String?
  recordingPermitted Boolean       @default(false)
  transcriptKey      String?
  backupContact      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  participants HearingParticipant[]
  rooms        HearingRoom[]

  @@index([caseId])
}

enum HearingRoomKind {
  TRIBUNAL
  PARTY_WAITING
  WITNESS_WAITING
  BREAKOUT
  MAIN
}

model HearingRoom {
  id        String          @id @default(uuid())
  hearingId String
  hearing   Hearing         @relation(fields: [hearingId], references: [id], onDelete: Cascade)
  kind      HearingRoomKind
  name      String
  joinUrl   String? // provider-issued, never stored in public dir
  createdAt DateTime        @default(now())
}

model HearingParticipant {
  id               String    @id @default(uuid())
  hearingId        String
  hearing          Hearing   @relation(fields: [hearingId], references: [id], onDelete: Cascade)
  userId           String?
  displayName      String
  role             String // tribunal | party | counsel | witness | interpreter | observer
  identityVerified Boolean   @default(false)
  attendedAt       DateTime?
  leftAt           DateTime?

  @@index([hearingId])
}

// ============================================================================
// FEES & PAYMENTS
// ============================================================================

model FeeEstimate {
  id          String   @id @default(uuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  category    String // FeeCategory key
  description String?
  amount      Decimal  @db.Decimal(18, 2)
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
  REFUNDED
}

model Invoice {
  id        String        @id @default(uuid())
  caseId    String
  case      Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  number    String        @unique
  status    InvoiceStatus @default(DRAFT)
  currency  String        @default("USD")
  subtotal  Decimal       @default(0) @db.Decimal(18, 2)
  tax       Decimal       @default(0) @db.Decimal(18, 2)
  total     Decimal       @default(0) @db.Decimal(18, 2)
  dueAt     DateTime?
  issuedAt  DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  allocations PaymentAllocation[]
  payments    Payment[]
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Payment {
  id                String        @id @default(uuid())
  caseId            String
  case              Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  invoiceId         String?
  invoice           Invoice?      @relation(fields: [invoiceId], references: [id])
  category          String
  amount            Decimal       @db.Decimal(18, 2)
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  provider          String        @default("manual")
  providerRef       String?
  // A party may pay another party's share without prejudice to the tribunal's
  // final decision on costs.
  paidByUserId      String?
  onBehalfOfPartyId String?
  receiptKey        String?
  recordedBy        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  allocations PaymentAllocation[]

  @@index([caseId])
}

model PaymentAllocation {
  id          String     @id @default(uuid())
  invoiceId   String
  invoice     Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentId   String?
  payment     Payment?   @relation(fields: [paymentId], references: [id])
  partyId     String
  side        PartySide?
  shareAmount Decimal    @db.Decimal(18, 2)
  currency    String     @default("USD")
  createdAt   DateTime   @default(now())
}

// ============================================================================
// AWARDS
// ============================================================================

enum AwardType {
  FINAL
  PARTIAL
  INTERIM
  CONSENT
  COSTS
  ADDITIONAL
}

model Award {
  id                     String    @id @default(uuid())
  caseId                 String
  case                   Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type                   AwardType
  issueDate              DateTime?
  seat                   String?
  signatureStatus        String    @default("PENDING") // PENDING | PARTIAL | SIGNED
  signedDocumentKey      String?
  signatureMetadata      String? // JSON: e-sign provider metadata
  generatedDocumentKey   String? // storage key of the platform-generated award PDF
  documentHash           String? // SHA-256 of the generated PDF (tamper-evident)
  certifiedCopyAvailable Boolean   @default(false)
  correctionStatus       String? // NONE | REQUESTED | ISSUED
  interpretationStatus   String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  deliveries  AwardDelivery[]
  corrections CorrectionRequest[]
}

model AwardDelivery {
  id              String    @id @default(uuid())
  awardId         String
  award           Award     @relation(fields: [awardId], references: [id], onDelete: Cascade)
  recipientUserId String?
  recipientLabel  String
  deliveredAt     DateTime?
  downloadedAt    DateTime?
  createdAt       DateTime  @default(now())
}

enum CorrectionKind {
  CORRECTION
  INTERPRETATION
  ADDITIONAL_AWARD
}

model CorrectionRequest {
  id          String         @id @default(uuid())
  awardId     String
  award       Award          @relation(fields: [awardId], references: [id], onDelete: Cascade)
  kind        CorrectionKind
  requestedBy String
  details     String
  status      String         @default("SUBMITTED")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ============================================================================
// TRIBUNAL DELIBERATIONS (strictly tribunal-only)
// ============================================================================

// Deliberation notes are readable ONLY by appointed tribunal members of the
// same case. No party, lawyer, registrar, admin, or council member may read
// them unless they are a tribunal member on this case. Enforced in service.
model DeliberationNote {
  id           String   @id @default(uuid())
  caseId       String
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tribunalId   String
  tribunal     Tribunal @relation(fields: [tribunalId], references: [id], onDelete: Cascade)
  authorUserId String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([caseId])
}

// ============================================================================
// CONTENT: NEWS, COURT HIGHLIGHTS, PUBLICATIONS
// ============================================================================

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model NewsArticle {
  id          String        @id @default(uuid())
  slug        String        @unique
  title       String
  excerpt     String?
  body        String
  category    String?
  tags        String[]      @default([])
  status      ContentStatus @default(DRAFT)
  authorName  String?
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model CourtHighlight {
  id           String        @id @default(uuid())
  slug         String        @unique
  courtName    String
  jurisdiction String
  caseName     String
  citation     String?
  decisionDate DateTime?
  legalIssue   String
  summary      String
  outcome      String?
  appealStatus String?
  source       String?
  authorName   String?
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  tags         String[]      @default([])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Publication {
  id          String        @id @default(uuid())
  slug        String        @unique
  title       String
  abstract    String?
  authorName  String?
  storageKey  String?
  externalUrl String?
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  tags        String[]      @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ============================================================================
// SESSIONS, AUTH TOKENS, AUDIT, SUPPORT, COMPLIANCE, IDENTITY, SETTINGS
// ============================================================================

model Session {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  deviceLabel      String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())

  @@index([userId])
}

enum LoginOutcome {
  SUCCESS
  FAILED
  LOCKED
  MFA_REQUIRED
}

model LoginEvent {
  id         String       @id @default(uuid())
  userId     String?
  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  email      String
  outcome    LoginOutcome
  ipAddress  String?
  userAgent  String?
  suspicious Boolean      @default(false)
  createdAt  DateTime     @default(now())

  @@index([userId])
  @@index([email])
}

enum EmailTokenKind {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model EmailToken {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      EmailTokenKind
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime       @default(now())

  @@index([userId])
}

// Append-only via the application layer (no update/delete exposed in UI/API).
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // e.g. DOCUMENT_DOWNLOAD, AWARD_DELIVERY
  entityType String?
  entityId   String?
  caseId     String?
  metadata   String? // JSON
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([caseId])
  @@index([action])
  @@index([userId])
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportTicket {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  body      String
  caseId    String?
  status    SupportStatus @default(OPEN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum ComplianceStatus {
  PENDING
  CLEARED
  FLAGGED
}

model ComplianceCheck {
  id         String           @id @default(uuid())
  caseId     String?
  case       Case?            @relation(fields: [caseId], references: [id], onDelete: SetNull)
  kind       String // conflict | sanctions | aml | quality
  status     ComplianceStatus @default(PENDING)
  note       String?
  reviewedBy String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model IdentityVerification {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String             @default("placeholder")
  status    VerificationStatus @default(PENDING)
  reference String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

// ============================================================================
// COMPLIANCE SCREENING (KYC / AML / SANCTIONS)
// A screening FRAMEWORK: it flags, holds and routes risk for human review. It
// does NOT make legal conclusions automatically. A possible match or provider
// failure raises a manual-review hold that an authorised reviewer must clear.
// Subject references are intentionally soft (no FK) so the same record can point
// at a party, company, lawyer, arbitrator, user or beneficial owner; only the
// minimal identifying data needed to screen and to audit is stored.
// ============================================================================

enum ScreeningSubjectType {
  PARTY
  COMPANY
  LAWYER
  ARBITRATOR
  INDIVIDUAL
  BENEFICIAL_OWNER
}

enum ScreeningType {
  SANCTIONS
  PEP
  ADVERSE_MEDIA
  AML
  IDENTITY
}

enum ScreeningStatus {
  NOT_SCREENED
  PENDING
  CLEAR
  POSSIBLE_MATCH
  FAILED
  EXPIRED
  MANUAL_REVIEW
}

enum ScreeningDecision {
  APPROVED
  REJECTED
  ESCALATED
}

enum ComplianceHoldStatus {
  ACTIVE
  RELEASED
}

model ScreeningCheck {
  id            String               @id @default(uuid())
  subjectType   ScreeningSubjectType
  subjectId     String? // soft reference to the screened entity
  subjectName   String // minimal identifying data actually screened
  caseId        String? // soft reference; screenings may be case-scoped or not
  screeningType ScreeningType
  status        ScreeningStatus      @default(PENDING)
  provider      String               @default("mock")
  providerRef   String?
  riskScore     Int?
  matchCount    Int                  @default(0)
  resultSummary String? // short human summary, NOT the full raw provider payload
  triggerEvent  String? // what caused this screening (filing, party add, …)
  requestedById String?
  screenedAt    DateTime?
  expiresAt     DateTime?
  // Manual review outcome
  reviewedById   String?
  reviewDecision ScreeningDecision?
  reviewNote     String?
  reviewedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  holds ComplianceHold[]

  @@index([subjectType, subjectId])
  @@index([caseId])
  @@index([status])
}

model ComplianceHold {
  id               String               @id @default(uuid())
  caseId           String? // a case-level hold freezes the case from proceeding
  subjectType      ScreeningSubjectType
  subjectId        String?
  reason           String
  status           ComplianceHoldStatus @default(ACTIVE)
  screeningCheckId String?
  screeningCheck   ScreeningCheck?      @relation(fields: [screeningCheckId], references: [id], onDelete: SetNull)
  createdById      String?
  releasedById     String?
  releaseNote      String?
  releasedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([caseId])
  @@index([status])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String // JSON
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// ============================================================================
// FEE SCHEDULES, DEPOSITS & FINANCIAL LEDGER (Chapter 18)
// NOTE: Client funds, escrow, trust accounts, payment-services regulation and
// banking arrangements require legal review before production launch.
// ============================================================================

enum FeeScheduleStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
}

enum FeeBasis {
  FLAT
  PER_ARBITRATOR
  PERCENTAGE
  AD_VALOREM
}

enum AllocationMethod {
  EQUAL
  BY_PARTY_COUNT
  BY_CLAIM_VALUE
  BY_CLAIM_AND_COUNTERCLAIM
  BY_TRIBUNAL
  BY_AGREEMENT
  CUSTOM
}

enum DepositStatus {
  REQUESTED
  PARTIALLY_PAID
  PAID
  IN_DEFAULT
  CANCELLED
}

enum ShareStatus {
  OUTSTANDING
  PARTIALLY_PAID
  PAID
  PAID_BY_SUBSTITUTE
  IN_DEFAULT
  WAIVED
}

model FeeSchedule {
  id            String   @id @default(uuid())
  code          String   @unique
  title         String
  titleAr       String?
  description   String?
  descriptionAr String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  versions FeeScheduleVersion[]
}

model FeeScheduleVersion {
  id            String            @id @default(uuid())
  feeScheduleId String
  feeSchedule   FeeSchedule       @relation(fields: [feeScheduleId], references: [id], onDelete: Cascade)
  version       String
  status        FeeScheduleStatus @default(DRAFT)
  currency      String            @default("USD")
  effectiveDate DateTime?
  supersededAt  DateTime?
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  items FeeScheduleItem[]

  @@unique([feeScheduleId, version])
}

model FeeScheduleItem {
  id         String             @id @default(uuid())
  versionId  String
  version    FeeScheduleVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  category   String // FILING | ADMINISTRATION | ARBITRATOR | HEARING_TECH | ...
  label      String
  labelAr    String?
  basis      FeeBasis           @default(FLAT)
  amount     Decimal?           @db.Decimal(18, 2)
  percentage Decimal?           @db.Decimal(6, 4)
  minAmount  Decimal?           @db.Decimal(18, 2)
  maxAmount  Decimal?           @db.Decimal(18, 2)
  sortOrder  Int                @default(0)
}

// A request for a deposit on account of costs, allocated among the parties.
model DepositRequest {
  id               String           @id @default(uuid())
  caseId           String
  case             Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  totalAmount      Decimal          @db.Decimal(18, 2)
  currency         String           @default("USD")
  allocationMethod AllocationMethod @default(EQUAL)
  status           DepositStatus    @default(REQUESTED)
  dueAt            DateTime?
  isSupplementary  Boolean          @default(false)
  requestedById    String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  allocations DepositAllocation[]

  @@index([caseId])
}

model DepositAllocation {
  id                      String         @id @default(uuid())
  depositRequestId        String
  depositRequest          DepositRequest @relation(fields: [depositRequestId], references: [id], onDelete: Cascade)
  partyId                 String
  side                    PartySide?
  shareAmount             Decimal        @db.Decimal(18, 2)
  paidAmount              Decimal        @default(0) @db.Decimal(18, 2)
  currency                String         @default("USD")
  status                  ShareStatus    @default(OUTSTANDING)
  // Substitute payment: another party paid this share without prejudice to the
  // tribunal's final decision on costs.
  paidBySubstitutePartyId String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  payments DepositPayment[]
  defaults PaymentDefault[]

  @@index([depositRequestId])
}

model DepositPayment {
  id            String            @id @default(uuid())
  allocationId  String
  allocation    DepositAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  amount        Decimal           @db.Decimal(18, 2)
  currency      String            @default("USD")
  paidByUserId  String?
  paidByPartyId String?
  substitute    Boolean           @default(false)
  provider      String            @default("manual")
  providerRef   String?
  receiptNumber String            @unique
  recordedById  String
  createdAt     DateTime          @default(now())

  refunds Refund[]

  @@index([allocationId])
}

model Refund {
  id             String         @id @default(uuid())
  paymentId      String
  payment        DepositPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amount         Decimal        @db.Decimal(18, 2)
  currency       String         @default("USD")
  reason         String
  status         String         @default("REQUESTED") // REQUESTED | APPROVED | PAID
  authorisedById String
  createdAt      DateTime       @default(now())
}

// Recorded when a party's share remains unpaid after the due date. The portal
// records the default but never auto-terminates a claim: consequences are for
// the tribunal / appointing authority.
model PaymentDefault {
  id                String            @id @default(uuid())
  allocationId      String
  allocation        DepositAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  partyId           String
  amountOutstanding Decimal           @db.Decimal(18, 2)
  currency          String            @default("USD")
  status            String            @default("OPEN") // OPEN | CURED_BY_PARTY | CURED_BY_SUBSTITUTE | REFERRED_TO_TRIBUNAL | RESOLVED
  declaredById      String
  referredAt        DateTime?
  resolvedAt        DateTime?
  note              String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([allocationId])
}

enum LedgerEntryKind {
  CHARGE
  PAYMENT
  REFUND
  ADJUSTMENT
  SUBSTITUTE_PAYMENT
}

// Append-only financial ledger per case (running record of charges/payments).
model FinancialLedgerEntry {
  id           String          @id @default(uuid())
  caseId       String
  case         Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  kind         LedgerEntryKind
  description  String
  amount       Decimal         @db.Decimal(18, 2) // signed: charges negative, payments positive
  currency     String          @default("USD")
  partyId      String?
  relatedType  String? // DepositRequest | DepositPayment | Refund | ...
  relatedId    String?
  recordedById String?
  createdAt    DateTime        @default(now())

  @@index([caseId])
}

// ============================================================================
// NORMALIZED RULES ENGINE (operational trigger → action graph)
//
// Existing scalar fields on `Rule` (triggeringEvent, requiredNotice, ...) are
// retained for backwards compatibility and the public site; these tables make
// the same intent operational so the engine can act on a case automatically.
// A reusable seed top-up backfills these rows from the scalar fields.
// ============================================================================

enum RuleActionKind {
  CREATE_DEADLINE // materialise a CaseDeadline from a RuleDeadlineDefinition
  REQUIRE_NOTICE // a formal notice must be served
  REQUIRE_DOCUMENT // a document/filing is required
  ASSESS_FEE // a fee/deposit consequence applies
  ADVANCE_STAGE // suggest a case-stage transition (never auto-decides merits)
  FLAG_DEFAULT // raise a default/non-participation flag for review
  RECORD_COMMENCEMENT // mark the arbitration commencement date
}

enum RuleExecutionStatus {
  EXECUTED
  SKIPPED // preconditions not met (e.g. definition missing)
  FAILED
  SUPERSEDED // later overridden by an authorised override/exception
}

// A condition that activates a rule: a procedural event type, optionally guarded.
model RuleTrigger {
  id            String  @id @default(uuid())
  ruleId        String
  rule          Rule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  eventType     String // CaseProceduralEvent.type that fires this trigger
  description   String?
  descriptionAr String?
  conditionJson String? // optional JSON guard evaluated against event metadata
  active        Boolean @default(true)
  sortOrder     Int     @default(0)

  actions RuleAction[]

  createdAt DateTime @default(now())

  @@unique([ruleId, eventType])
  @@index([eventType])
}

// What the engine does when a trigger fires.
model RuleAction {
  id            String         @id @default(uuid())
  triggerId     String
  trigger       RuleTrigger    @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  kind          RuleActionKind
  // For CREATE_DEADLINE: the RuleDeadlineDefinition.key to materialise.
  definitionKey String?
  // For REQUIRE_NOTICE / REQUIRE_DOCUMENT / ASSESS_FEE: a stable reference key.
  targetKey     String?
  paramsJson    String? // additional parameters (JSON)
  sortOrder     Int            @default(0)

  createdAt DateTime @default(now())

  @@index([triggerId])
}

// A formal notice a rule requires (Chapter 2 service linkage).
model RuleNoticeRequirement {
  id            String     @id @default(uuid())
  ruleId        String
  rule          Rule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  noticeType    NoticeType
  recipientRole CaseRole?
  description   String?
  descriptionAr String?

  @@index([ruleId])
}

// A document/filing a rule requires.
model RuleDocumentRequirement {
  id        String  @id @default(uuid())
  ruleId    String
  rule      Rule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  key       String // stable key, e.g. PROOF_OF_AUTHORITY
  label     String
  labelAr   String?
  mandatory Boolean @default(true)

  @@unique([ruleId, key])
}

// A fee/deposit consequence a rule defines.
model RuleFeeDefinition {
  id            String   @id @default(uuid())
  ruleId        String
  rule          Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  feeCode       String // e.g. FILING_FEE, INITIAL_DEPOSIT
  basis         FeeBasis @default(FLAT)
  amount        Decimal? @db.Decimal(18, 2)
  currency      String   @default("USD")
  description   String?
  descriptionAr String?

  @@unique([ruleId, feeCode])
}

// A permission/role a rule requires to perform its action.
model RulePermissionRequirement {
  id          String  @id @default(uuid())
  ruleId      String
  rule        Rule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  permission  String // Permission enum value (string) or role name
  description String?

  @@index([ruleId])
}

// An authorised, recorded modification of a rule for ONE case (agreed by the
// parties). Immutable: preserves the original and the override value + authority.
model CaseRuleOverride {
  id             String   @id @default(uuid())
  caseId         String
  case           Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  ruleId         String
  rule           Rule     @relation(fields: [ruleId], references: [id])
  field          String // which rule aspect is overridden, e.g. DEADLINE_DAYS
  originalValue  String?
  overrideValue  String
  reason         String?
  authorisedById String?
  authorityBasis String? // PARTY_AGREEMENT | TRIBUNAL_DIRECTION
  createdAt      DateTime @default(now())

  @@index([caseId])
  @@index([ruleId])
}

// A tribunal/mandatory-law exception: a procedural step modified to preserve
// fairness/due process, or displaced by mandatory law of the seat. Immutable.
model CaseRuleException {
  id             String   @id @default(uuid())
  caseId         String
  case           Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  ruleId         String?
  rule           Rule?    @relation(fields: [ruleId], references: [id])
  reason         String
  mandatoryLaw   Boolean  @default(false) // true = displaced by mandatory law of the seat
  authorisedById String?
  authorityBasis String? // TRIBUNAL | APPOINTING_AUTHORITY | MANDATORY_LAW
  createdAt      DateTime @default(now())

  @@index([caseId])
}

// Provenance: every concrete action the engine took on a case, with the event
// and rule that produced it and the entity it created.
model CaseRuleExecution {
  id                String               @id @default(uuid())
  caseId            String
  case              Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  ruleId            String
  rule              Rule                 @relation(fields: [ruleId], references: [id])
  triggerEventId    String?
  triggerEvent      CaseProceduralEvent? @relation(fields: [triggerEventId], references: [id])
  actionKind        RuleActionKind
  status            RuleExecutionStatus  @default(EXECUTED)
  detail            String? // JSON
  createdEntityType String? // Deadline | FormalNotice | DepositRequest | ...
  createdEntityId   String?
  executedAt        DateTime             @default(now())

  @@index([caseId])
  @@index([ruleId])
  @@index([triggerEventId])
}

// Append-only audit log specific to rule lifecycle and engine execution.
// Normal users/admins must not edit or delete these rows.
model RuleAuditLog {
  id               String   @id @default(uuid())
  ruleSetVersionId String?
  ruleId           String?
  rule             Rule?    @relation(fields: [ruleId], references: [id])
  caseId           String?
  case             Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  action           String // RULE_TRIGGER_FIRED | RULE_ACTION_EXECUTED | OVERRIDE_RECORDED ...
  actorUserId      String?
  detail           String? // JSON
  createdAt        DateTime @default(now())

  @@index([caseId])
  @@index([ruleId])
}

// ============================================================================
// FILINGS / PLEADINGS (Chapter 10)
// A filing is a procedural submission (Statement of Claim, Defence, ...). Filed
// documents are never silently replaced: a correction creates a NEW version
// that supersedes the prior one, with full reason/approval provenance.
// ============================================================================

enum FilingType {
  STATEMENT_OF_CLAIM
  STATEMENT_OF_DEFENCE
  COUNTERCLAIM
  DEFENCE_TO_COUNTERCLAIM
  REPLY
  REJOINDER
  AMENDMENT
  JURISDICTIONAL_SUBMISSION
  PROCEDURAL_APPLICATION
  POST_HEARING_SUBMISSION
}

enum FilingStatus {
  DRAFT
  SUBMITTED
  RECEIVED
  ACCEPTED
  REJECTED
  SUPERSEDED // replaced by a later corrected version
  CORRECTED // this version was corrected (a superseding version exists)
}

enum FilingFeeStatus {
  NOT_REQUIRED
  PENDING
  PAID
  WAIVED
}

enum CorrectionApproval {
  PENDING
  APPROVED
  REJECTED
}

model Filing {
  id                   String               @id @default(uuid())
  caseId               String
  case                 Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  filingNumber         String // e.g. F-0001 (per case)
  type                 FilingType
  title                String
  partyId              String?
  representativeUserId String?
  submittedById        String
  submittedAt          DateTime?
  officialTimezone     String               @default("UTC")
  version              Int                  @default(1)
  contentHash          String? // hash sealing the filed content/bundle
  confidentiality      ConfidentialityLevel @default(CASE_PARTIES)
  feeStatus            FilingFeeStatus      @default(NOT_REQUIRED)
  status               FilingStatus         @default(SUBMITTED)
  // Version chain: a correction creates a new Filing that supersedes the prior.
  supersedesId         String?              @unique
  supersedes           Filing?              @relation("FilingVersions", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy         Filing?              @relation("FilingVersions")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  documents   FilingDocument[]
  receipt     FilingReceipt?
  corrections FilingCorrection[]

  @@unique([caseId, filingNumber])
  @@index([caseId])
  @@index([status])
}

model FilingDocument {
  id         String   @id @default(uuid())
  filingId   String
  filing     Filing   @relation(fields: [filingId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([filingId, documentId])
}

// Immutable filing receipt: a sealed acknowledgement of a completed filing.
model FilingReceipt {
  id            String   @id @default(uuid())
  filingId      String   @unique
  filing        Filing   @relation(fields: [filingId], references: [id], onDelete: Cascade)
  receiptNumber String   @unique
  payload       String // JSON snapshot
  payloadHash   String
  generatedAt   DateTime @default(now())
}

// A correction request on a filed document — creates a new version, never edits.
model FilingCorrection {
  id              String             @id @default(uuid())
  filingId        String
  filing          Filing             @relation(fields: [filingId], references: [id], onDelete: Cascade)
  reason          String
  requestedById   String
  approval        CorrectionApproval @default(PENDING)
  approvedById    String?
  previousVersion Int
  newVersion      Int
  newFilingId     String? // the superseding Filing created on approval
  createdAt       DateTime           @default(now())

  @@index([filingId])
}

// ============================================================================
// DOCUMENT PRODUCTION (Chapter 12) — Redfern-style request schedule.
// The portal records the schedule; only the tribunal decides production.
// ============================================================================

enum ProductionStatus {
  REQUESTED
  OBJECTED
  REPLIED
  GRANTED
  GRANTED_IN_PART
  DENIED
  PRODUCED
  NON_COMPLIANCE
}

model ProductionRequest {
  id                   String           @id @default(uuid())
  caseId               String
  case                 Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  requestNumber        String // e.g. R-0001 (per case)
  requestingPartyId    String?
  requestedById        String
  category             String // requested category/description of documents
  relevance            String?
  materiality          String?
  objection            String?
  objectedById         String?
  reply                String?
  tribunalDecision     String?
  decisionReason       String?
  decidedById          String?
  privilegeClaim       String?
  confidentialityOrder String?
  status               ProductionStatus @default(REQUESTED)
  dueAt                DateTime?
  producedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  documents ProductionDocument[]

  @@unique([caseId, requestNumber])
  @@index([caseId])
  @@index([status])
}

model ProductionDocument {
  id         String            @id @default(uuid())
  requestId  String
  request    ProductionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  documentId String
  document   Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@unique([requestId, documentId])
}

// ============================================================================
// WITNESS EVIDENCE (Chapter 13) & EXPERT EVIDENCE (Chapter 14)
// The tribunal rules on admissibility and weight; the portal only records the
// evidence and its provenance.
// ============================================================================

enum WitnessStatus {
  PROPOSED
  CONFIRMED
  WITHDRAWN
  TESTIFIED
}

enum OathKind {
  NONE
  OATH
  AFFIRMATION
}

model Witness {
  id                   String        @id @default(uuid())
  caseId               String
  case                 Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  partyId              String? // the party calling the witness
  fullName             String
  capacity             String? // fact witness, custodian, etc.
  language             String        @default("en")
  interpreterRequired  Boolean       @default(false)
  availabilityNote     String?
  identityVerified     Boolean       @default(false)
  isolationAcknowledged Boolean      @default(false) // witness-isolation protocol accepted
  crossExaminationRequired Boolean   @default(false)
  hearingAttendance    String? // INVITED | CONFIRMED | ATTENDED | ABSENT
  oath                 OathKind      @default(NONE)
  oathRecordedAt       DateTime?
  status               WitnessStatus @default(PROPOSED)
  proposedById         String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  statements WitnessStatement[]

  @@index([caseId])
}

model WitnessStatement {
  id            String   @id @default(uuid())
  witnessId     String
  witness       Witness  @relation(fields: [witnessId], references: [id], onDelete: Cascade)
  title         String
  language      String   @default("en")
  documentId    String? // links to the uploaded statement Document
  version       Int      @default(1)
  submittedById String
  submittedAt   DateTime @default(now())

  @@index([witnessId])
}

enum ExpertAppointment {
  PARTY_APPOINTED
  TRIBUNAL_APPOINTED
}

enum ExpertStatus {
  PROPOSED
  APPOINTED
  REPORTED
  WITHDRAWN
}

enum ExpertReportKind {
  REPORT
  REPLY_REPORT
  JOINT_STATEMENT
}

model Expert {
  id                 String            @id @default(uuid())
  caseId             String
  case               Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  appointment        ExpertAppointment
  partyId            String? // null for tribunal-appointed
  fullName           String
  expertise          String
  instructions       String?
  independenceDeclared Boolean         @default(false)
  conflictDisclosed  Boolean           @default(false)
  feeArrangement     String?
  status             ExpertStatus      @default(PROPOSED)
  proposedById       String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  reports ExpertReport[]

  @@index([caseId])
}

model ExpertReport {
  id            String           @id @default(uuid())
  expertId      String
  expert        Expert           @relation(fields: [expertId], references: [id], onDelete: Cascade)
  kind          ExpertReportKind @default(REPORT)
  title         String
  documentId    String?
  version       Int              @default(1)
  submittedById String
  submittedAt   DateTime         @default(now())

  @@index([expertId])
}

enum EvidenceTargetType {
  DOCUMENT
  WITNESS
  WITNESS_STATEMENT
  EXPERT
  EXPERT_REPORT
}

enum EvidenceObjectionStatus {
  RAISED
  UPHELD
  DISMISSED
  DEFERRED
}

// A party objection to evidence (authenticity, admissibility, privilege, ...).
// Only the tribunal rules on it.
model EvidenceObjection {
  id          String                  @id @default(uuid())
  caseId      String
  case        Case                    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  targetType  EvidenceTargetType
  targetId    String
  ground      String // AUTHENTICITY | ADMISSIBILITY | PRIVILEGE | RELEVANCE | ...
  detail      String?
  raisedById  String
  status      EvidenceObjectionStatus @default(RAISED)
  ruling      String?
  ruledById   String?
  ruledAt     DateTime?
  createdAt   DateTime                @default(now())

  @@index([caseId])
  @@index([targetType, targetId])
}

// ============================================================================
// DEFAULT / NON-PARTICIPATION PROCEEDINGS (Chapter 17)
//
// Due-process safeguard: failure to participate must NEVER automatically result
// in an award for the other party. Before the tribunal may proceed in default,
// a full review (agreement, jurisdiction, valid service, delivery records,
// opportunity to respond, evidence, explanation, applicable law, fairness) must
// be satisfied and a registrar report with verified service must exist.
// ============================================================================

enum DefaultStage {
  OPENED
  WARNING_ISSUED
  FINAL_REMINDER_ISSUED
  REGISTRAR_REVIEW
  TRIBUNAL_REVIEW
  PROCEED_AUTHORISED
  PROCEED_REFUSED
  CURED
}

enum DefaultNoticeKind {
  WARNING
  FINAL_REMINDER
}

enum DefaultReviewFactor {
  ARBITRATION_AGREEMENT
  JURISDICTION
  VALID_SERVICE
  DELIVERY_RECORDS
  OPPORTUNITY_TO_RESPOND
  EVIDENCE
  EXPLANATION_FOR_ABSENCE
  APPLICABLE_LAW
  FAIRNESS
}

enum DefaultOutcome {
  PROCEED
  REFUSE
  CURED
}

model DefaultProceeding {
  id                   String       @id @default(uuid())
  caseId               String
  case                 Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  defaultingPartyId    String?
  defaultingParticipant String // legal name / role of the non-participating party
  basis                String // what was missed, e.g. RESPONSE_NOT_FILED, DEPOSIT_UNPAID
  stage                DefaultStage @default(OPENED)
  openedById           String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  notices         DefaultNotice[]
  reviewItems     DefaultReviewItem[]
  registrarReport DefaultRegistrarReport?
  decision        DefaultDecision?

  @@index([caseId])
}

model DefaultNotice {
  id           String            @id @default(uuid())
  proceedingId String
  proceeding   DefaultProceeding @relation(fields: [proceedingId], references: [id], onDelete: Cascade)
  kind         DefaultNoticeKind
  body         String
  deadlineAt   DateTime?
  issuedById   String
  issuedAt     DateTime          @default(now())

  @@index([proceedingId])
}

model DefaultReviewItem {
  id           String              @id @default(uuid())
  proceedingId String
  proceeding   DefaultProceeding   @relation(fields: [proceedingId], references: [id], onDelete: Cascade)
  factor       DefaultReviewFactor
  satisfied    Boolean             @default(false)
  note         String?
  reviewedById String?
  reviewedAt   DateTime?

  @@unique([proceedingId, factor])
}

model DefaultRegistrarReport {
  id             String            @id @default(uuid())
  proceedingId   String            @unique
  proceeding     DefaultProceeding @relation(fields: [proceedingId], references: [id], onDelete: Cascade)
  summary        String
  serviceVerified Boolean          @default(false)
  preparedById   String
  preparedAt     DateTime          @default(now())
}

// The tribunal's reasoned decision. PROCEED only authorises proceeding in the
// party's absence — it never, by itself, establishes the other party's claim.
model DefaultDecision {
  id                      String            @id @default(uuid())
  proceedingId            String            @unique
  proceeding              DefaultProceeding @relation(fields: [proceedingId], references: [id], onDelete: Cascade)
  outcome                 DefaultOutcome
  reason                  String
  defaultHearingScheduled Boolean           @default(false)
  proceduralOrderRef      String?
  decidedById             String
  decidedAt               DateTime          @default(now())
}

// ============================================================================
// INTERIM & EMERGENCY MEASURES (Chapter 16)
//
// The portal records the application, opposition and the tribunal's decision —
// it NEVER itself grants relief. Only the tribunal may grant, modify or
// discharge an interim measure.
// ============================================================================

enum InterimMeasureType {
  ASSET_PRESERVATION
  EVIDENCE_PRESERVATION
  CONFIDENTIALITY
  SECURITY_FOR_COSTS
  STATUS_QUO
  INSPECTION
  DOCUMENT_PRESERVATION
  URGENT_PROTECTION
  OTHER
}

enum InterimUrgency {
  STANDARD
  URGENT
  EMERGENCY
}

enum InterimStatus {
  APPLIED
  OPPOSED
  UNDER_CONSIDERATION
  GRANTED
  GRANTED_IN_PART
  DENIED
  MODIFIED
  DISCHARGED
}

enum InterimEventKind {
  NOTICE
  OPPOSITION
  DECISION
  MODIFICATION
  DISCHARGE
  COMPLIANCE
}

model InterimMeasure {
  id               String             @id @default(uuid())
  caseId           String
  case             Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  measureNumber    String // e.g. IM-0001 (per case)
  type             InterimMeasureType
  urgency          InterimUrgency     @default(STANDARD)
  applicantPartyId String?
  appliedById      String
  reliefSought     String
  grounds          String?
  status           InterimStatus      @default(APPLIED)
  decision         String?
  decisionReason   String?
  decidedById      String?
  decidedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  events InterimMeasureEvent[]

  @@unique([caseId, measureNumber])
  @@index([caseId])
  @@index([status])
}

model InterimMeasureEvent {
  id        String           @id @default(uuid())
  measureId String
  measure   InterimMeasure   @relation(fields: [measureId], references: [id], onDelete: Cascade)
  kind      InterimEventKind
  detail    String
  actorById String
  createdAt DateTime         @default(now())

  @@index([measureId])
}

// ============================================================================
// EXPEDITED PROCEDURE (Chapter 23)
//
// An OPTIONAL track. It is never applied automatically: it requires party
// agreement or another legally valid basis, and an explicit authorised
// activation.
// ============================================================================

enum ExpeditedBasis {
  PARTY_AGREEMENT
  RULES_THRESHOLD // claim value below an agreed threshold, where the rules permit
  OTHER_LEGAL_BASIS
}

enum ExpeditedStatus {
  PROPOSED
  AGREED
  ACTIVE
  DECLINED
  TERMINATED
}

model ExpeditedTrack {
  id                    String          @id @default(uuid())
  caseId                String          @unique
  case                  Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  basis                 ExpeditedBasis
  status                ExpeditedStatus @default(PROPOSED)
  soleArbitrator        Boolean         @default(true)
  documentsOnly         Boolean         @default(false)
  pageLimit             Int?
  awardTargetDays       Int?
  deadlineScalePercent  Int             @default(50) // shorter deadlines (% of standard)
  simplifiedFeeSchedule Boolean         @default(true)
  proposedById          String
  activatedById         String?
  activatedAt           DateTime?
  terminatedReason      String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  consents ExpeditedConsent[]
}

model ExpeditedConsent {
  id        String         @id @default(uuid())
  trackId   String
  track     ExpeditedTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  userId    String
  partyId   String?
  consented Boolean
  note      String?
  createdAt DateTime       @default(now())

  @@unique([trackId, userId])
}

// ============================================================================
// MULTI-PARTY & MULTI-CONTRACT (Chapter 24) — consolidation & joinder
//
// The tribunal or the appointing authority decides; the portal records the
// request, party comments and the decision.
// ============================================================================

enum JoinderType {
  CONSOLIDATION
  JOINDER
}

enum JoinderStatus {
  REQUESTED
  COMMENTS_OPEN
  GRANTED
  DENIED
  WITHDRAWN
}

model PartyJoinderRequest {
  id                 String        @id @default(uuid())
  caseId             String
  case               Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type               JoinderType
  requestNumber      String // e.g. J-0001 (per case)
  subjectDescription String // the party/contract/case to join or consolidate
  relatedCaseRef     String?
  requestingPartyId  String?
  requestedById      String
  grounds            String?
  status             JoinderStatus @default(REQUESTED)
  decision           String?
  decisionReason     String?
  decidedById        String?
  decidedAt          DateTime?
  feeReallocationNote String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  comments JoinderComment[]

  @@unique([caseId, requestNumber])
  @@index([caseId])
}

model JoinderComment {
  id          String              @id @default(uuid())
  requestId   String
  request     PartyJoinderRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorById  String
  partyId     String?
  comment     String
  createdAt   DateTime            @default(now())

  @@index([requestId])
}
